VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
# Nur Root-URL, ohne Pfad (kein /emails am Ende):
VITE_FIREBASE_DATABASE_URL=https://YOUR_PROJECT_ID-default-rtdb.europe-west1.firebasedatabase.app
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional: Realtime-Database-Pfad. Standard = Root (leer lassen), wie bei n8n push().
# Nur setzen, wenn Mails in einem Unterordner liegen:
# VITE_FIREBASE_EMAILS_PATH=emails

# --- KI-Suche (Vercel Serverless Function /api/gemini-search) ---
# In Vercel (Serverless /api): GEMINI_API_KEY und Projekt-ID.
# FIREBASE_PROJECT_ID=...  (oder nur VITE_FIREBASE_PROJECT_ID – API nutzt das als Fallback)
# GEMINI_API_KEY=...       (alternativ: GOOGLE_GENERATIVE_AI_API_KEY)
# Optional: GEMINI_MODEL=gemini-3.1-flash-lite-preview
#
# Lokal mit `npx vercel dev -l 3000` und Vite-Proxy:
# VITE_API_BASE_URL=http://127.0.0.1:3000
